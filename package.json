{
  "name": "natav",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "vite",
    "start": "react-router-serve ./build/server/index.js",
    "typegen:rr": "react-router typegen && tsc",
    "typegen:ba": "@better-auth/cli generate --config ./app/.server/auth.ts --output ./app/.server/drizzle/schema.auth.ts -y",
    "typegen:db": "drizzle-kit generate --config ./app/.server/drizzle/config.ts",
    "typegen": "bun run typegen:rr && bun run typegen:ba && bun run typegen:db",
    "db:migrate": "drizzle-kit migrate --config ./app/.server/drizzle/config.ts",
    "db:push": "drizzle-kit push --config ./app/.server/drizzle/config.ts",
    "db:studio": "drizzle-kit studio --config ./app/.server/drizzle/config.ts"
  },
  "dependencies": {
    "@better-auth/passkey": "^1.4.19",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/api-logs": "^0.212.0",
    "@opentelemetry/core": "^2.5.1",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.212.0",
    "@opentelemetry/instrumentation-pino": "^0.58.0",
    "@opentelemetry/sdk-logs": "^0.212.0",
    "@opentelemetry/sdk-node": "^0.212.0",
    "@react-email/components": "^1.0.8",
    "@react-email/render": "^2.0.4",
    "@react-router/node": "^7.13.1",
    "@react-router/serve": "^7.13.1",
    "better-auth": "^1.4.19",
    "better-sqlite3": "^12.6.2",
    "drizzle-orm": "^0.45.1",
    "isbot": "^5.1.35",
    "pino": "^10.3.1",
    "qrcode": "^1.5.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "^7.13.1",
    "resend": "^6.9.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@better-auth/cli": "^1.4.19",
    "@react-router/dev": "^7.13.1",
    "@tailwindcss/vite": "^4.2.1",
    "@types/qrcode": "^1.5.6",
    "@types/bun": "^1.3.9",
    "@types/node": "^20.19.35",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.9",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^6.4.1",
    "vite-tsconfig-paths": "^5.1.4"
  }
}
