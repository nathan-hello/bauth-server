{
  "name": "natav",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bunx --bun react-router build",
    "dev": "bunx --bun vite",
    "start": "bun --env-file=.env ./build/server/index.js",
    "typegen:rr": "bunx --bun react-router typegen && tsc",
    "typegen:ba": "bunx --bun @better-auth/cli generate --config ./app/.server/auth.ts --output ./app/.server/drizzle/schema.auth.ts -y",
    "typegen:db": "bunx --bun drizzle-kit generate --config ./app/.server/drizzle/config.ts",
    "typegen": "bun run typegen:rr && bun run typegen:ba && bun run typegen:db",
    "db:migrate": "bunx --bun drizzle-kit migrate --config ./app/.server/drizzle/config.ts",
    "db:push": "bunx --bun drizzle-kit push --config ./app/.server/drizzle/config.ts",
    "db:studio": "bunx --bun drizzle-kit studio --config ./app/.server/drizzle/config.ts"
  },
  "dependencies": {
    "@better-auth/passkey": "^1.4.10",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/api-logs": "^0.212.0",
    "@opentelemetry/core": "^2.5.1",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.212.0",
    "@opentelemetry/instrumentation-pino": "^0.58.0",
    "@opentelemetry/sdk-logs": "^0.212.0",
    "@opentelemetry/sdk-node": "^0.212.0",
    "@react-email/components": "^1.0.8",
    "@react-email/render": "^2.0.4",
    "@react-router/node": "^7.11.0",
    "@react-router/serve": "^7.11.0",
    "better-auth": "^1.4.19",
    "drizzle-orm": "^0.45.1",
    "isbot": "^5",
    "pino": "^10.3.1",
    "qrcode": "^1.5.4",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-router": "^7.11.0",
    "react-router-hono-server": "^2.25.0",
    "resend": "^6.9.2",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@better-auth/cli": "^1.4.19",
    "@react-router/dev": "^7.11.0",
    "@tailwindcss/vite": "^4.1.18",
    "@types/qrcode": "^1.5.6",
    "@types/bun": "^1.3.9",
    "@types/node": "^20.19.27",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.8",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "vite": "^6.4.1",
    "vite-tsconfig-paths": "^5.1.4"
  }
}
